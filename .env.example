# ═══════════════════════════════════════════
# VaultX Agent Configuration
# ═══════════════════════════════════════════

# Agent identity
VAULTX_AGENT_ID=vault-primary-001
VAULTX_NETWORK=testnet

# Treasury limits
VAULTX_TOTAL_BUDGET=10000
VAULTX_ALERT_THRESHOLD=0.2
VAULTX_MAX_SINGLE_TX=500

# x402 Protocol
VAULTX_X402_ENDPOINT=https://x402.testnet.vaultx.dev/v1
VAULTX_X402_TIMEOUT_MS=3000

# KYA (Know Your Agent) scoring
VAULTX_KYA_MIN_SCORE=0.6
VAULTX_KYA_CHECK_INTERVAL_S=30

# Simulation speed (ms between events in the loop)
VAULTX_TICK_INTERVAL_MS=2000

# Logging
VAULTX_LOG_LEVEL=info
